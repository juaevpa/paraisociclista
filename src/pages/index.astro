---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import RouteCard from '@/components/RouteCard.astro';
import PlaceCard from '@/components/PlaceCard.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import { sanityClient, queries } from '@/lib/sanity';

const homeData = await sanityClient.fetch(queries.homeContent);
---

<Layout title="Inicio">
  <Header />

  <main class="flex-1 bg-white">
    <!-- HERO editorial: foto panorámica real de Xàtiva + tipografía serif -->
    <section class="relative overflow-hidden bg-stone-900">
      <img
        src="/images/blog/xativa-panoramic.jpg"
        alt="Vista panorámica de Xàtiva desde el castillo"
        class="absolute inset-0 w-full h-full object-cover opacity-60"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-stone-900/40 via-stone-900/20 to-stone-900/70"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 lg:py-44">
        <div class="max-w-4xl">
          <p class="text-[11px] uppercase tracking-[0.35em] font-semibold text-white/80 mb-6">
            Cicloturismo en la Costera · Xàtiva
          </p>
          <h1 class="font-serif text-white font-light leading-[0.95] tracking-tight text-5xl md:text-7xl lg:text-[96px]">
            Un paraíso<br />
            <em class="italic font-normal">a golpe</em> de pedal
          </h1>
          <p class="mt-8 text-lg md:text-xl text-white/85 max-w-xl leading-relaxed">
            Selección de rutas, consejos reales y la guía local de Xàtiva para quien rueda.
            Entre la costa y la montaña, una tierra con tradición ciclista profunda.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a
              href="/rutas"
              class="inline-flex items-center gap-3 px-6 py-3.5 bg-white text-stone-900 font-semibold text-sm uppercase tracking-wider hover:bg-stone-100 transition-colors"
            >
              Explorar rutas
              <span aria-hidden="true">→</span>
            </a>
            <a
              href="/sobre-nosotros"
              class="inline-flex items-center gap-3 px-6 py-3.5 text-white font-semibold text-sm uppercase tracking-wider border border-white/40 hover:bg-white/10 transition-colors"
            >
              El proyecto
            </a>
          </div>
        </div>
      </div>

      <!-- Meta-strip inferior -->
      <div class="relative border-t border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
            <div class="py-5 md:py-6 px-2 md:px-6">
              <div class="font-serif text-2xl md:text-3xl font-light text-white">300+</div>
              <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-white/70">días de sol</div>
            </div>
            <div class="py-5 md:py-6 px-4 md:px-6">
              <div class="font-serif text-2xl md:text-3xl font-light text-white">4</div>
              <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-white/70">Comarcas</div>
            </div>
            <div class="py-5 md:py-6 px-4 md:px-6">
              <div class="font-serif text-2xl md:text-3xl font-light text-white">1.800m</div>
              <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-white/70">Desnivel máx.</div>
            </div>
            <div class="py-5 md:py-6 px-4 md:px-6">
              <div class="font-serif text-2xl md:text-3xl font-light text-white">1591</div>
              <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-white/70">Ribera nació aquí</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- RUTAS DESTACADAS -->
    <section class="border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
          <div>
            <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-3">
              Selección · 01
            </p>
            <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-tight tracking-tight max-w-3xl">
              Rutas <em class="italic font-normal">destacadas</em>
            </h2>
            <p class="mt-4 text-stone-600 max-w-xl leading-relaxed">
              Los itinerarios imprescindibles para empezar a conocer la comarca sobre dos ruedas.
            </p>
          </div>
          <a
            href="/rutas"
            class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.25em] font-semibold text-stone-900 hover:gap-4 transition-all"
          >
            Ver todas
            <span aria-hidden="true">→</span>
          </a>
        </div>

        {homeData.featuredRoutes && homeData.featuredRoutes.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {homeData.featuredRoutes.map((route: any, i: number) => (
              <RouteCard route={route} index={i} />
            ))}
          </div>
        ) : (
          <div class="border border-dashed border-stone-300 py-16 text-center">
            <p class="text-stone-500">Aún no hay rutas destacadas.</p>
          </div>
        )}
      </div>
    </section>

    <!-- DONDE COMER Y ALOJARSE -->
    <section class="border-b border-stone-200 bg-stone-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="mb-12">
          <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-3">
            Selección · 02
          </p>
          <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-tight tracking-tight max-w-3xl">
            Dónde comer<br />y <em class="italic font-normal">dormir</em>
          </h2>
          <p class="mt-4 text-stone-600 max-w-xl leading-relaxed">
            Restaurantes con alma, obradores históricos y alojamientos bike-friendly para planificar tu estancia.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {homeData.latestRestaurants?.map((r: any) => (
            <PlaceCard place={r} type="restaurant" />
          ))}
          {homeData.latestHotels?.map((h: any) => (
            <PlaceCard place={h} type="hotel" />
          ))}
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a
            href="/restaurantes"
            class="inline-flex items-center gap-2 px-5 py-3 bg-stone-900 text-white text-xs uppercase tracking-[0.2em] font-semibold hover:bg-stone-800 transition-colors"
          >
            Restaurantes <span aria-hidden="true">→</span>
          </a>
          <a
            href="/alojamiento"
            class="inline-flex items-center gap-2 px-5 py-3 bg-white text-stone-900 border border-stone-300 text-xs uppercase tracking-[0.2em] font-semibold hover:bg-stone-100 transition-colors"
          >
            Alojamiento <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- EXPLORAR XATIVA -->
    <section>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="mb-12">
          <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-3">
            Selección · 03
          </p>
          <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-tight tracking-tight max-w-3xl">
            Explora <em class="italic font-normal">Xàtiva</em>
          </h2>
          <p class="mt-4 text-stone-600 max-w-xl leading-relaxed">
            Del castillo de los Borgia al retrato invertido de Felipe V, pasando por el arnadí y la moixavena: lo que hay que ver entre pedalada y pedalada.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {homeData.exploreCategories?.map((c: any) => (
            <CategoryCard category={c} />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
