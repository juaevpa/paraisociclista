---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, queries, urlFor } from '@/lib/sanity';
import { fixPortableText } from '@/lib/fixPortableText';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const routes = await sanityClient.fetch(`*[_type == "route"]{ slug }`);
  return routes.map((route: any) => ({
    params: { slug: route.slug.current },
  }));
}

const { slug } = Astro.params;
const route = await sanityClient.fetch(queries.routeBySlug, { slug });

if (!route) {
  return Astro.redirect('/404');
}

const difficultyColors: Record<string, { bg: string; text: string; emoji: string }> = {
  green:  { bg: 'bg-emerald-100', text: 'text-emerald-700', emoji: '🟢' },
  yellow: { bg: 'bg-amber-100',   text: 'text-amber-700',   emoji: '🟡' },
  orange: { bg: 'bg-orange-100',  text: 'text-orange-700',  emoji: '🟠' },
  red:    { bg: 'bg-red-100',     text: 'text-red-700',     emoji: '🔴' },
};

const diff = route.difficulty
  ? { ...difficultyColors[route.difficulty.color] ?? difficultyColors.green, label: route.difficulty.title }
  : null;
---

<Layout title={route.title}>
  <Header />

  <main class="flex-1 bg-gradient-to-br from-slate-50 via-white to-sky-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumb -->
      <nav class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-primary-600">Inicio</a></li>
          <li>/</li>
          <li><a href="/rutas" class="hover:text-primary-600">Rutas</a></li>
          <li>/</li>
          <li class="text-slate-900 font-medium">{route.title}</li>
        </ol>
      </nav>

      <!-- Imagen principal -->
      {route.mainImage && (
        <div class="relative rounded-2xl overflow-hidden shadow-xl mb-8">
          <div class="aspect-[21/9] w-full">
            <img
              src={urlFor(route.mainImage).width(1400).height(600).url()}
              alt={route.title}
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>

          <!-- Badges -->
          <div class="absolute top-4 left-4 flex gap-2">
            {route.featured && (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-yellow-400 text-yellow-900 shadow-lg">
                ⭐ Destacada
              </span>
            )}
            {diff && (
              <span class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold ${diff.bg} ${diff.text} shadow-lg`}>
                {diff.emoji} {diff.label}
              </span>
            )}
          </div>
        </div>
      )}

      <!-- Contenido -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Columna principal -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h1 class="text-4xl font-black text-slate-900">{route.title}</h1>
            {route.routeType && (
              <div class="flex gap-2 mt-3">
                <span class="inline-flex items-center gap-1.5 text-sm text-primary-600 bg-primary-50 px-3 py-1 rounded-full">
                  {route.routeType.icon && <span>{route.routeType.icon}</span>}
                  <span>{route.routeType.title}</span>
                </span>
              </div>
            )}
            {route.excerpt && (
              <p class="mt-4 text-lg text-slate-600 leading-relaxed">{route.excerpt}</p>
            )}
          </div>

          <!-- Descripción -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8">
            <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
              📍 Descripción de la Ruta
            </h2>
            <div class="prose prose-slate max-w-none" set:html={route.description ? toHTML(fixPortableText(route.description)) : '<p class="text-slate-500 italic">Descripción no disponible.</p>'}>
            </div>
          </div>

          <!-- Mapa embed (Wikiloc u otro) -->
          {route.mapEmbed && (
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
              <div class="px-6 py-4 border-b border-slate-100">
                <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
                  🗺️ Mapa de la Ruta
                </h2>
              </div>
              <div class="map-embed-wrapper" set:html={route.mapEmbed}></div>
            </div>
          )}

          <!-- Galería -->
          {route.gallery && route.gallery.length > 0 && (
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8">
              <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                🖼️ Galería
              </h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                {route.gallery.map((img: any) => (
                  <div class="aspect-square rounded-xl overflow-hidden">
                    <img
                      src={urlFor(img).width(600).height(600).url()}
                      alt={route.title}
                      class="w-full h-full object-cover hover:scale-105 transition-transform"
                      loading="lazy"
                    />
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24">
            <h3 class="text-lg font-semibold text-slate-900 mb-6">
              Información de la Ruta
            </h3>

            <div class="space-y-5">
              {route.distance && (
                <div class="flex items-center gap-4">
                  <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-sky-100 flex items-center justify-center">
                    <span class="text-2xl">🚴</span>
                  </div>
                  <div>
                    <p class="text-sm text-slate-500">Distancia</p>
                    <p class="text-xl font-bold text-slate-900">{route.distance} km</p>
                  </div>
                </div>
              )}

              {route.elevation && (
                <div class="flex items-center gap-4">
                  <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center">
                    <span class="text-2xl">⛰️</span>
                  </div>
                  <div>
                    <p class="text-sm text-slate-500">Desnivel</p>
                    <p class="text-xl font-bold text-slate-900">{route.elevation} m</p>
                  </div>
                </div>
              )}

              {route.duration && (
                <div class="flex items-center gap-4">
                  <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-indigo-100 flex items-center justify-center">
                    <span class="text-2xl">⏱️</span>
                  </div>
                  <div>
                    <p class="text-sm text-slate-500">Duración estimada</p>
                    <p class="text-xl font-bold text-slate-900">{route.duration}</p>
                  </div>
                </div>
              )}

              {diff && (
                <div class="flex items-center gap-4">
                  <div class={`flex-shrink-0 w-12 h-12 rounded-xl ${diff.bg} flex items-center justify-center`}>
                    <span class="text-2xl">{diff.emoji}</span>
                  </div>
                  <div>
                    <p class="text-sm text-slate-500">Dificultad</p>
                    <p class={`text-xl font-bold ${diff.text}`}>{diff.label}</p>
                  </div>
                </div>
              )}

              {route.featured && (
                <div class="flex items-center gap-4">
                  <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-yellow-100 flex items-center justify-center">
                    <span class="text-2xl">⭐</span>
                  </div>
                  <div>
                    <p class="text-sm text-slate-500">Estado</p>
                    <p class="text-lg font-bold text-yellow-600">Ruta Destacada</p>
                  </div>
                </div>
              )}
            </div>

            {route.gpxFile && (
              <>
                <hr class="my-6 border-slate-100" />
                <a
                  href={route.gpxFile}
                  download
                  target="_blank"
                  rel="noopener"
                  class="flex items-center justify-center gap-2 w-full px-5 py-3 bg-gradient-to-r from-sky-500 to-blue-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all"
                >
                  ⬇️ Descargar archivo GPX
                </a>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .map-embed-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }
  .map-embed-wrapper iframe,
  .map-embed-wrapper embed,
  .map-embed-wrapper object {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    border: 0;
  }
</style>
