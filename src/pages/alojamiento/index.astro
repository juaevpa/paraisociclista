---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, queries, urlFor } from '@/lib/sanity';

const hotels = await sanityClient.fetch(queries.allHotels);
---

<Layout title="Alojamiento" description="Los mejores hoteles y alojamientos en Xàtiva">
  <Header />
  
  <main class="flex-1">
    <!-- Hero -->
    <section class="relative py-16 md:py-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-black text-white">
          🏨 Alojamiento en Xàtiva
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          Encuentra el mejor lugar para descansar después de tus rutas
        </p>
      </div>
    </section>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {hotels.map((hotel: any) => (
          <article class="group bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl transition-all duration-300">
            <a href={`/alojamiento/${hotel.slug.current}`} class="block">
              <div class="relative aspect-[16/10] overflow-hidden bg-slate-100">
                {hotel.mainImage ? (
                  <img 
                    src={urlFor(hotel.mainImage).width(600).height(375).url()} 
                    alt={hotel.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center">
                    <span class="text-5xl">🏨</span>
                  </div>
                )}
              </div>
            </a>
            
            <div class="p-5">
              <a href={`/alojamiento/${hotel.slug.current}`}>
                <h3 class="text-lg font-semibold text-slate-900 group-hover:text-primary-600 transition-colors">
                  {hotel.title}
                </h3>
              </a>
              
              <div class="flex items-center justify-between mt-3">
                {hotel.rating && (
                  <div class="flex items-center gap-1 text-amber-500">
                    {[...Array(5)].map((_, i) => (
                      <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 ${i < hotel.rating ? 'fill-current' : 'fill-slate-200'}`} viewBox="0 0 24 24">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    ))}
                    <span class="ml-1 text-slate-600 text-sm">{hotel.rating}/5</span>
                  </div>
                )}
                
                {hotel.priceLevel && (
                  <span class="text-slate-500 text-sm">
                    {'€'.repeat(hotel.priceLevel)}
                  </span>
                )}
              </div>
              
              {hotel.address && (
                <p class="mt-2 text-slate-500 text-sm flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  {hotel.address}
                </p>
              )}
              
              <a 
                href={`/alojamiento/${hotel.slug.current}`}
                class="mt-4 flex items-center justify-center gap-2 w-full py-2.5 px-4 bg-slate-100 hover:bg-indigo-500 text-slate-700 hover:text-white rounded-xl text-sm font-medium transition-all duration-200"
              >
                Ver detalles
              </a>
            </div>
          </article>
        ))}
      </div>
      
      {hotels.length === 0 && (
        <div class="text-center py-16">
          <span class="text-6xl">🏨</span>
          <p class="mt-4 text-slate-500 text-lg">No hay alojamientos todavía.</p>
          <p class="text-slate-400">¡Añade contenido desde el panel de Sanity!</p>
        </div>
      )}
    </div>
  </main>
  
  <Footer />
</Layout>
