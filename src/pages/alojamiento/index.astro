---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, queries, urlFor } from '@/lib/sanity';

const hotels = await sanityClient.fetch(queries.allHotels);
---

<Layout title="Alojamiento · Paraíso Ciclista" description="Hoteles, casas rurales y apartamentos bike-friendly en Xàtiva y su comarca.">
  <Header />

  <main class="flex-1 bg-white">
    <!-- Hero editorial -->
    <section class="border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
          <div class="lg:col-span-8">
            <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
              Alojamiento · Xàtiva
            </p>
            <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-light text-stone-900 leading-[1.02] tracking-tight">
              Dónde <em class="italic font-normal">dormir</em><br />
              tras la ruta
            </h1>
          </div>
          <div class="lg:col-span-4 lg:pl-8 lg:border-l border-stone-200">
            <p class="text-base md:text-lg text-stone-600 leading-relaxed">
              Hoteles, casas rurales y apartamentos en Xàtiva y comarca. Selección con atención al ciclista: parking para bicis, desayuno temprano y punto de lavado.
            </p>
            <div class="mt-6 text-[11px] uppercase tracking-[0.2em] text-stone-500 font-semibold">
              {hotels.length} alojamientos
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {hotels.map((h: any, idx: number) => {
          const num = String(idx + 1).padStart(2, '0');
          return (
            <a href={`/alojamiento/${h.slug.current}`} class="group block">
              <div class="relative aspect-[5/4] overflow-hidden bg-stone-100 mb-4">
                {h.mainImage ? (
                  <img
                    src={urlFor(h.mainImage).width(700).height(560).url()}
                    alt={h.title}
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 bg-stone-200 flex items-center justify-center">
                    <span class="font-serif text-6xl font-light text-stone-400">{num}</span>
                  </div>
                )}
              </div>

              <div class="flex items-start justify-between gap-4 mb-1">
                <span class="font-serif text-sm text-stone-400 font-light">{num}</span>
                {h.rating && (
                  <span class="text-[11px] uppercase tracking-[0.2em] font-semibold text-stone-600">
                    {h.rating.toFixed(1)} / 5
                  </span>
                )}
              </div>
              <h3 class="font-serif text-xl md:text-2xl font-light text-stone-900 leading-[1.15] tracking-tight group-hover:text-stone-600 transition-colors">
                {h.title}
              </h3>
              {h.address && (
                <p class="mt-2 text-sm text-stone-500 line-clamp-1">{h.address}</p>
              )}
            </a>
          );
        })}
      </div>

      {hotels.length === 0 && (
        <div class="border border-dashed border-stone-300 py-16 text-center">
          <p class="text-stone-500">No hay alojamientos todavía.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
