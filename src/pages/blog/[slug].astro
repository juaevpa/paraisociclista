---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, queries } from '@/lib/sanity';
import { getPostImage, hasPostImage } from '@/lib/postImages';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "blogPost"]{ slug }`);
  return posts.map((p: any) => ({ params: { slug: p.slug.current } }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch(queries.blogPostBySlug, { slug });
if (!post) return Astro.redirect('/404');

const relatedPosts = await sanityClient.fetch(
  `*[_type == "blogPost" && slug.current != $slug][0...3] {
    _id, title, slug, mainImage, excerpt
  }`,
  { slug }
);

const heroImage = hasPostImage(post) ? getPostImage(post, 1920, 1080) : null;
---

<Layout title={post.title}>
  <Header />

  <main class="flex-1 bg-white">
    <!-- Hero -->
    {heroImage ? (
      <section class="relative w-full h-[55vh] min-h-[380px] max-h-[560px] overflow-hidden">
        <img src={heroImage} alt={post.title} class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent"></div>
        <div class="absolute inset-0 flex items-end">
          <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 w-full">
            <nav class="mb-5">
              <ol class="flex items-center gap-2 text-sm text-white/80">
                <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
                <li class="opacity-60">/</li>
                <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
              </ol>
            </nav>
            <h1 class="text-3xl md:text-5xl font-black text-white leading-[1.1] drop-shadow-2xl">
              {post.title}
            </h1>
          </div>
        </div>
      </section>
    ) : (
      <section class="relative bg-gradient-to-br from-emerald-600 via-teal-600 to-sky-700 py-24 overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image:radial-gradient(circle at 20% 50%, white 1px, transparent 1px), radial-gradient(circle at 80% 80%, white 1px, transparent 1px);background-size:32px 32px;"></div>
        <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <nav class="mb-5">
            <ol class="flex items-center gap-2 text-sm text-white/80">
              <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
              <li class="opacity-60">/</li>
              <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            </ol>
          </nav>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider mb-4">
            🚴 Artículo
          </div>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-[1.1] drop-shadow-lg">
            {post.title}
          </h1>
        </div>
      </section>
    )}

    <!-- Contenido -->
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      {post.excerpt && (
        <p class="text-lg md:text-xl text-slate-600 leading-relaxed font-normal mb-10 pb-10 border-b border-slate-200 italic">
          {post.excerpt}
        </p>
      )}

      <div class="post-content" set:html={post.content ? toHTML(post.content) : '<p>Contenido no disponible.</p>'}></div>

      <div class="mt-16 pt-8 border-t border-slate-200">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-slate-100 text-slate-700 hover:bg-slate-200 font-semibold transition-colors"
        >
          ← Volver al blog
        </a>
      </div>
    </article>

    <!-- Posts relacionados -->
    {relatedPosts.length > 0 && (
      <section class="bg-slate-50 border-t border-slate-200 py-16">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-8">Sigue leyendo</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map((rp: any) => (
              <a
                href={`/blog/${rp.slug.current}`}
                class="group bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all"
              >
                <div class="aspect-video overflow-hidden bg-gradient-to-br from-emerald-500 to-sky-600 flex items-center justify-center">
                  {hasPostImage(rp) ? (
                    <img
                      src={getPostImage(rp, 600, 338)}
                      alt={rp.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <span class="text-5xl">🚴</span>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="font-bold text-slate-900 group-hover:text-primary-600 transition-colors line-clamp-2">
                    {rp.title}
                  </h3>
                  {rp.excerpt && (
                    <p class="mt-2 text-slate-500 text-sm line-clamp-2">{rp.excerpt}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
  /* Tipografía limpia para contenido migrado — neutraliza el bold-everywhere
     y los links indebidos que arrastran los posts importados desde WordPress */
  .post-content {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #334155;
  }

  .post-content > * + * {
    margin-top: 1.25rem;
  }

  /* Párrafos: fuerza peso normal aunque venga envuelto en <strong> */
  .post-content p {
    font-weight: 400;
    color: #334155;
  }
  .post-content p strong {
    font-weight: 400;
    color: inherit;
  }

  /* Anula colores heredados de enlaces cuando envuelven bloques enteros */
  .post-content p > a:only-child,
  .post-content a {
    color: #0284c7;
    text-decoration: underline;
    text-decoration-color: rgba(2, 132, 199, 0.35);
    text-underline-offset: 3px;
    font-weight: 500;
  }
  .post-content a:hover {
    color: #0369a1;
    text-decoration-color: currentColor;
  }

  /* Encabezados — todos los niveles con jerarquía clara */
  .post-content h1,
  .post-content h2,
  .post-content h3,
  .post-content h4,
  .post-content h5,
  .post-content h6 {
    color: #0f172a;
    font-weight: 800;
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .post-content h1 { font-size: 2.25rem; }
  .post-content h2 { font-size: 1.875rem; }
  .post-content h3 { font-size: 1.5rem; }
  .post-content h4 { font-size: 1.25rem; }
  .post-content h5 { font-size: 1.125rem; }
  .post-content h6 { font-size: 1rem; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; }

  /* Primer encabezado sin margen superior */
  .post-content > h1:first-child,
  .post-content > h2:first-child,
  .post-content > h3:first-child {
    margin-top: 0;
  }

  /* Neutraliza bold en encabezados que vengan con strong anidado */
  .post-content h1 strong,
  .post-content h2 strong,
  .post-content h3 strong,
  .post-content h4 strong,
  .post-content h5 strong,
  .post-content h6 strong {
    font-weight: inherit;
    color: inherit;
  }

  /* Listas */
  .post-content ul,
  .post-content ol {
    padding-left: 1.5rem;
    margin: 1.25rem 0;
  }
  .post-content ul { list-style: disc; }
  .post-content ol { list-style: decimal; }
  .post-content li {
    margin: 0.5rem 0;
    color: #334155;
  }
  .post-content li::marker {
    color: #10b981;
  }
  .post-content li strong {
    font-weight: 600;
    color: #0f172a;
  }

  /* Citas */
  .post-content blockquote {
    border-left: 4px solid #10b981;
    background: #ecfdf5;
    padding: 1rem 1.5rem;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #334155;
    font-style: italic;
    margin: 1.5rem 0;
  }

  /* Imágenes */
  .post-content img {
    border-radius: 1rem;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
    margin: 2rem 0;
    max-width: 100%;
    height: auto;
  }

  /* Código */
  .post-content code {
    background: #f1f5f9;
    color: #db2777;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
  .post-content pre {
    background: #0f172a;
    color: #e2e8f0;
    padding: 1.25rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .post-content pre code {
    background: none;
    color: inherit;
    padding: 0;
  }

  /* Separadores */
  .post-content hr {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, #cbd5e1, transparent);
    margin: 2.5rem 0;
  }
</style>
