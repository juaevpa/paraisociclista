---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, queries, urlFor } from '@/lib/sanity';

const posts = await sanityClient.fetch(queries.allBlogPosts);
---

<Layout title="Blog" description="Noticias y artículos sobre ciclismo en Xàtiva">
  <Header />
  
  <main class="flex-1">
    <section class="relative py-16 md:py-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-slate-700 via-slate-800 to-slate-900"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-black text-white">📝 Blog</h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">Noticias, consejos y artículos sobre ciclismo</p>
      </div>
    </section>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post: any) => (
          <article class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl transition-all">
            <a href={`/blog/${post.slug.current}`} class="block aspect-video overflow-hidden bg-slate-100">
              {post.mainImage ? (
                <img src={urlFor(post.mainImage).width(600).height(338).url()} alt={post.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center"><span class="text-4xl">📝</span></div>
              )}
            </a>
            <div class="p-5">
              {post.publishedAt && <p class="text-slate-500 text-sm mb-2">{new Date(post.publishedAt).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
              <a href={`/blog/${post.slug.current}`}><h3 class="text-lg font-semibold text-slate-900 hover:text-primary-600 transition-colors line-clamp-2">{post.title}</h3></a>
              {post.excerpt && <p class="mt-2 text-slate-500 text-sm line-clamp-3">{post.excerpt}</p>}
              <a href={`/blog/${post.slug.current}`} class="mt-4 inline-flex items-center text-primary-600 hover:text-primary-700 font-medium text-sm">Leer más →</a>
            </div>
          </article>
        ))}
      </div>
      {posts.length === 0 && <div class="text-center py-16"><span class="text-6xl">📝</span><p class="mt-4 text-slate-500 text-lg">No hay artículos todavía.</p></div>}
    </div>
  </main>
  
  <Footer />
</Layout>
