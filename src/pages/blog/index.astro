---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, queries } from '@/lib/sanity';
import { getPostImage, hasPostImage } from '@/lib/postImages';

const posts = await sanityClient.fetch(queries.allBlogPosts);
---

<Layout title="Diario · Paraíso Ciclista" description="Artículos, consejos y reportajes sobre ciclismo en Xàtiva y su comarca.">
  <Header />

  <main class="flex-1 bg-white">
    <!-- Hero editorial -->
    <section class="border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
          <div class="lg:col-span-8">
            <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
              Diario · Artículos
            </p>
            <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-light text-stone-900 leading-[1.02] tracking-tight">
              Crónicas <em class="italic font-normal">desde</em><br />
              el manillar
            </h1>
          </div>
          <div class="lg:col-span-4 lg:pl-8 lg:border-l border-stone-200">
            <p class="text-base md:text-lg text-stone-600 leading-relaxed">
              Reflexiones, consejos prácticos y reportajes sobre cicloturismo, entrenamiento, cultura local y todo lo que pasa mientras se pedalea por Xàtiva.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post: any, idx: number) => {
          const num = String(idx + 1).padStart(2, '0');
          return (
            <article class="group">
              <a href={`/blog/${post.slug.current}`} class="block">
                <div class="relative aspect-[5/4] overflow-hidden bg-stone-100 mb-5">
                  {hasPostImage(post) ? (
                    <img
                      src={getPostImage(post, 800, 640)}
                      alt={post.title}
                      class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                      loading="lazy"
                    />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center bg-stone-200">
                      <span class="font-serif text-6xl font-light text-stone-400">{num}</span>
                    </div>
                  )}
                </div>
                <p class="text-[11px] uppercase tracking-[0.25em] font-semibold text-stone-500 mb-2">
                  Artículo · {num}
                </p>
                <h3 class="font-serif text-2xl md:text-3xl font-light text-stone-900 leading-[1.1] tracking-tight group-hover:text-stone-700 transition-colors">
                  {post.title}
                </h3>
                {post.excerpt && (
                  <p class="mt-3 text-stone-600 leading-relaxed line-clamp-3">
                    {post.excerpt}
                  </p>
                )}
                <div class="mt-4 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] font-semibold text-stone-900 group-hover:gap-3 transition-all">
                  Leer artículo <span aria-hidden="true">→</span>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="border border-dashed border-stone-300 py-16 text-center">
          <p class="text-stone-500">No hay artículos todavía.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
