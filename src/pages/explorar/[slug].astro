---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, urlFor } from '@/lib/sanity';

export async function getStaticPaths() {
  const categories = await sanityClient.fetch(`*[_type == "exploreCategory"]{ slug }`);
  return categories.map((c: any) => ({ params: { slug: c.slug.current } }));
}

const { slug } = Astro.params;
const category = await sanityClient.fetch(`*[_type == "exploreCategory" && slug.current == $slug][0]`, { slug });
const places = await sanityClient.fetch(`*[_type == "explorePlace" && category->slug.current == $slug]{ _id, title, slug, mainImage, description }`, { slug });

if (!category) return Astro.redirect('/404');
---

<Layout title={category.title}>
  <Header />
  
  <main class="flex-1">
    <section class="relative py-16 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-sky-500 to-teal-500"></div>
      <div class="relative max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-4xl font-black text-white">{category.title}</h1>
        {category.description && <p class="mt-4 text-white/80">{category.description}</p>}
      </div>
    </section>
    
    <div class="max-w-7xl mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {places.map((place: any) => (
          <article class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl transition-all">
            <a href={`/explorar/${slug}/${place.slug.current}`} class="block aspect-video overflow-hidden">
              {place.mainImage ? (
                <img src={urlFor(place.mainImage).width(600).height(338).url()} alt={place.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-sky-100 to-teal-100 flex items-center justify-center"><span class="text-4xl">📍</span></div>
              )}
            </a>
            <div class="p-5">
              <a href={`/explorar/${slug}/${place.slug.current}`}><h3 class="text-lg font-semibold hover:text-primary-600 transition-colors">{place.title}</h3></a>
            </div>
          </article>
        ))}
      </div>
      {places.length === 0 && <div class="text-center py-16 text-slate-500">No hay lugares en esta categoría todavía.</div>}
    </div>
  </main>
  
  <Footer />
</Layout>
