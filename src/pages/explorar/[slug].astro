---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { sanityClient, urlFor } from '@/lib/sanity';
import { getCategoryImage } from '@/lib/placeImages';

export async function getStaticPaths() {
  const categories = await sanityClient.fetch(`*[_type == "exploreCategory"]{ slug }`);
  return categories.map((c: any) => ({ params: { slug: c.slug.current } }));
}

const { slug } = Astro.params;
const category = await sanityClient.fetch(
  `*[_type == "exploreCategory" && slug.current == $slug][0]`,
  { slug }
);
const places = await sanityClient.fetch(
  `*[_type == "explorePlace" && category->slug.current == $slug]{ _id, title, slug, mainImage, excerpt }`,
  { slug }
);

if (!category) return Astro.redirect('/404');

const heroImage = getCategoryImage(slug);
---

<Layout title={`${category.title} · Explorar Xàtiva`} description={category.description}>
  <Header />

  <main class="flex-1 bg-white">
    <!-- Hero editorial con foto si existe -->
    {heroImage ? (
      <section class="relative overflow-hidden bg-stone-900">
        <img
          src={heroImage}
          alt={category.title}
          class="absolute inset-0 w-full h-full object-cover opacity-55"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-stone-900/50 via-stone-900/30 to-stone-900/75"></div>
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
          <nav class="mb-6">
            <ol class="flex items-center gap-2 text-xs text-white/70 uppercase tracking-widest">
              <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
              <li class="opacity-60">/</li>
              <li><a href="/explorar" class="hover:text-white transition-colors">Explorar</a></li>
            </ol>
          </nav>
          <p class="text-[11px] uppercase tracking-[0.35em] font-semibold text-white/80 mb-4">
            Explorar · Xàtiva
          </p>
          <h1 class="font-serif text-white font-light text-5xl md:text-7xl leading-[1.02] tracking-tight">
            {category.title}
          </h1>
          {category.description && (
            <p class="mt-6 text-lg md:text-xl text-white/85 max-w-2xl leading-relaxed">
              {category.description}
            </p>
          )}
        </div>
      </section>
    ) : (
      <section class="border-b border-stone-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
          <nav class="mb-6">
            <ol class="flex items-center gap-2 text-xs text-stone-500 uppercase tracking-widest">
              <li><a href="/" class="hover:text-stone-900 transition-colors">Inicio</a></li>
              <li class="opacity-60">/</li>
              <li><a href="/explorar" class="hover:text-stone-900 transition-colors">Explorar</a></li>
            </ol>
          </nav>
          <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
            Explorar · Xàtiva
          </p>
          <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-light text-stone-900 leading-[1.02] tracking-tight">
            {category.title}
          </h1>
          {category.description && (
            <p class="mt-6 text-lg md:text-xl text-stone-600 max-w-2xl leading-relaxed">
              {category.description}
            </p>
          )}
        </div>
      </section>
    )}

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <p class="text-[11px] uppercase tracking-[0.25em] font-semibold text-stone-500 mb-8">
        {places.length} {places.length === 1 ? 'lugar' : 'lugares'} en esta categoría
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {places.map((place: any, idx: number) => {
          const num = String(idx + 1).padStart(2, '0');
          return (
            <a href={`/explorar/${slug}/${place.slug.current}`} class="group block">
              <div class="relative aspect-[5/4] overflow-hidden bg-stone-100 mb-4">
                {place.mainImage ? (
                  <img
                    src={urlFor(place.mainImage).width(700).height(560).url()}
                    alt={place.title}
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 bg-stone-200 flex items-center justify-center">
                    <span class="font-serif text-6xl font-light text-stone-400">{num}</span>
                  </div>
                )}
              </div>
              <span class="font-serif text-sm text-stone-400 font-light">{num}</span>
              <h3 class="mt-1 font-serif text-2xl md:text-3xl font-light text-stone-900 leading-[1.1] tracking-tight group-hover:text-stone-600 transition-colors">
                {place.title}
              </h3>
              {place.excerpt && (
                <p class="mt-3 text-stone-600 leading-relaxed line-clamp-3">{place.excerpt}</p>
              )}
              <div class="mt-4 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] font-semibold text-stone-900 group-hover:gap-3 transition-all">
                Descubrir <span aria-hidden="true">→</span>
              </div>
            </a>
          );
        })}
      </div>

      {places.length === 0 && (
        <div class="border border-dashed border-stone-300 py-16 text-center">
          <p class="text-stone-500">No hay lugares en esta categoría todavía.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
