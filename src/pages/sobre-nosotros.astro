---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

const stats = [
  { value: '300+', label: 'Días de sol al año' },
  { value: '6', label: 'Rutas verificadas' },
  { value: '4', label: 'Comarcas al alcance' },
  { value: '775', label: 'Años de la Fira d’Agost' },
];

const values = [
  {
    icon: '🗺️',
    title: 'Rutas probadas, no copiadas',
    text: 'Cada itinerario que publico lo he rodado metro a metro. Sé dónde hay una fuente operativa, qué bar abre el domingo por la mañana y qué puerto conviene afrontar a primera hora.',
  },
  {
    icon: '🌿',
    title: 'Cicloturismo con potencial',
    text: 'Xàtiva tiene todo lo que un destino cicloturista puede ofrecer: clima, orografía, patrimonio, gastronomía y carreteras tranquilas. Falta ordenarlo y contarlo bien. Esa es la misión.',
  },
  {
    icon: '📍',
    title: 'Conocimiento local',
    text: 'No hablo de oídas. Vivo aquí, como arròs al forn los jueves, subo al castillo al amanecer y sé por qué el retrato de Felipe V sigue cabeza abajo en el Almodí.',
  },
  {
    icon: '🤝',
    title: 'Proyecto abierto',
    text: 'Esta web crece con quien la usa. Si echas en falta una ruta, un taller o un bar bike-friendly, escríbeme y lo incorporo. La comunidad ciclista local está invitada a colaborar.',
  },
];

const offerings = [
  {
    title: 'Rutas con GPX',
    text: 'Mapas, desnivel, duración, dificultad y tracks descargables compatibles con Wikiloc, Komoot y Strava.',
  },
  {
    title: 'Guía gastronómica',
    text: 'Restaurantes, bares de pueblo y obradores históricos donde comer de verdad: arròs al forn, arnadí, moixavena.',
  },
  {
    title: 'Alojamiento bike-friendly',
    text: 'Selección de hoteles, casas rurales y apartamentos adaptados a ciclistas en Xàtiva y comarca.',
  },
  {
    title: 'Cultura y patrimonio',
    text: 'El castillo, la Seu, el Museu de l’Almodí, los Borgia: lo que hay que parar a ver entre pedalada y pedalada.',
  },
  {
    title: 'Consejos prácticos',
    text: 'Mejores épocas, mecánica básica, talleres de bici en Xàtiva, puntos de agua, seguridad vial y preparación.',
  },
  {
    title: 'Eventos y pruebas',
    text: 'Volta a la Comunitat Valenciana, Trofeo de Velocidad de la Fira (desde 1951), concentraciones y marchas locales.',
  },
];
---

<Layout title="Sobre Paraíso Ciclista" description="Paraíso Ciclista: la guía independiente para descubrir Xàtiva en bicicleta, hecha por ciclistas locales que conocen cada carretera, fuente y bar del camino.">
  <Header />

  <main class="flex-1 bg-white">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-600 via-teal-600 to-sky-700"></div>
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, white 1px, transparent 1px), radial-gradient(circle at 80% 70%, white 1px, transparent 1px); background-size: 40px 40px;"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/15 backdrop-blur-sm text-white/90 text-xs font-semibold uppercase tracking-[0.2em] mb-6">
          🚴 Paraíso Ciclista
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-white leading-[1.05] drop-shadow-lg">
          La guía honesta de Xàtiva<br />para quien rueda
        </h1>
        <p class="mt-6 text-lg md:text-xl text-white/85 max-w-2xl mx-auto leading-relaxed">
          Un proyecto personal e independiente para poner en valor el enorme potencial cicloturista de Xàtiva y su comarca. Rutas probadas, consejos reales y una mirada auténtica sobre una tierra con una tradición ciclista profunda.
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="bg-slate-50 border-b border-slate-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {stats.map((s) => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-black bg-gradient-to-br from-emerald-600 to-sky-600 bg-clip-text text-transparent">
                {s.value}
              </div>
              <div class="mt-1 text-sm text-slate-600 font-medium">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Historia / Por qué -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="prose prose-lg prose-slate max-w-none">
        <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight !mt-0">
          ¿Por qué existe esta web?
        </h2>
        <p class="text-slate-600 leading-relaxed">
          Paraíso Ciclista es un proyecto <strong>personal</strong>. Detrás no hay una empresa ni un colectivo: hay una persona, aficionada al ciclismo, que vive en Xàtiva y tiene una convicción clara: <strong>esta comarca tiene un potencial cicloturista enorme y aún por poner en valor</strong>.
        </p>
        <p class="text-slate-600 leading-relaxed">
          Xàtiva no necesita inventarse como destino ciclista; ya lo es desde hace generaciones. Aquí se celebra desde 1951 el <strong>Trofeo de Velocidad Fira de Xàtiva</strong>, la carrera urbana más antigua de España en activo. Los clubes locales llevan décadas formando cantera, los sábados por la mañana los puertos de la Vall d’Albaida y del Canal de Navarrés se llenan de ciclistas, y en los bares de los pueblos los maillots y los cafés conviven con una naturalidad que delata la costumbre.
        </p>
        <p class="text-slate-600 leading-relaxed">
          Pero cuando buscaba información online para planificar rutas, recomendar la zona a amigos de fuera o explicar por qué merece la pena venir, solo encontraba guías copiadas unas de otras, datos desactualizados, rutas que nadie había pedaleado y recomendaciones gastronómicas genéricas. Xàtiva merece una guía mejor.
        </p>
        <p class="text-slate-600 leading-relaxed">
          Esta es mi aportación: una guía honesta, rodada, verificada y con memoria local. Sin patrocinios de marcas, ayuntamientos ni hoteles. Si recomiendo un restaurante es porque he comido allí; si publico una ruta es porque la he rodado. La independencia es lo único que hace útil una guía turística.
        </p>
        <p class="text-slate-600 leading-relaxed">
          El objetivo a medio plazo es sencillo pero ambicioso: que quien busque "cicloturismo en la Comunitat Valenciana" encuentre Xàtiva entre las primeras respuestas, con razones sobradas para venir. Si te apasiona el ciclismo y la zona, estás invitado a sumar.
        </p>
      </div>
    </section>

    <!-- Valores -->
    <section class="bg-slate-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
        <div class="max-w-2xl mb-12">
          <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">Cómo trabajamos</h2>
          <p class="mt-3 text-slate-600 text-lg">
            Cuatro principios que orientan todo lo que publicamos aquí.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {values.map((v) => (
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-100 to-sky-100 flex items-center justify-center text-2xl mb-4">
                {v.icon}
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">{v.title}</h3>
              <p class="text-slate-600 leading-relaxed">{v.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tradición ciclista de la zona -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="bg-gradient-to-br from-amber-50 via-white to-orange-50 rounded-3xl border border-amber-100 p-8 md:p-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 text-amber-800 text-xs font-semibold uppercase tracking-[0.2em] mb-5">
          🏆 Tradición ciclista
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">
          Xàtiva es, históricamente, una tierra de ciclistas
        </h2>
        <p class="mt-4 text-slate-600 text-lg leading-relaxed max-w-3xl">
          Aquí el ciclismo no es una moda: es costumbre. Son décadas de clubes locales, de carreras en el asfalto de las calles del centro, de aficionados que suben al castillo en bici antes del desayuno y de pelotones de fin de semana que dominan las carreteras de la comarca.
        </p>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="text-3xl font-black text-amber-600">1951</div>
            <div class="mt-2 font-bold text-slate-900">Trofeo de Velocidad Fira</div>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">
              Carrera urbana ininterrumpida durante la Fira d'Agost. La más antigua de España en activo.
            </p>
          </div>
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="text-3xl font-black text-emerald-600">Volta</div>
            <div class="mt-2 font-bold text-slate-900">Comunitat Valenciana</div>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">
              Xàtiva ha sido salida y meta de etapa en la Volta, con el castillo como final explosivo reconocido en el circuito profesional.
            </p>
          </div>
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="text-3xl font-black text-sky-600">Cantera</div>
            <div class="mt-2 font-bold text-slate-900">Clubes locales</div>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">
              Los clubes de Xàtiva y pueblos vecinos (Canals, Genovés, Ontinyent) han formado durante décadas sub-23 con proyección nacional.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Qué encontrarás -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="max-w-2xl mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">Qué vas a encontrar</h2>
        <p class="mt-3 text-slate-600 text-lg">
          Seis bloques de contenido que cubren todo lo que necesitas para planificar tu visita ciclista a Xàtiva.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {offerings.map((o, i) => (
          <div class="relative bg-gradient-to-br from-white to-slate-50 rounded-2xl border border-slate-200 p-6 hover:border-emerald-300 hover:shadow-lg transition-all">
            <div class="absolute top-4 right-5 text-5xl font-black text-emerald-100 leading-none">
              {String(i + 1).padStart(2, '0')}
            </div>
            <h3 class="relative text-lg font-bold text-slate-900 mb-2 pr-12">{o.title}</h3>
            <p class="relative text-sm text-slate-600 leading-relaxed">{o.text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Xàtiva -->
    <section class="relative overflow-hidden bg-slate-900">
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 30% 20%, #10b981 1px, transparent 1px), radial-gradient(circle at 70% 80%, #0ea5e9 1px, transparent 1px); background-size: 50px 50px;"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 text-emerald-300 text-xs font-semibold uppercase tracking-[0.2em] mb-6">
          🗺️ Ubicación privilegiada
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-white tracking-tight">
          Xàtiva, el mejor sitio para rodar en la Comunitat Valenciana
        </h2>
        <div class="mt-6 space-y-4 text-slate-300 leading-relaxed text-lg">
          <p>
            A 50 minutos de Valencia y a poco más de una hora de Alicante, Xàtiva es bisagra entre la costa y las sierras prelitorales. Desde el mismo punto de partida puedes elegir un día de llaneo por la huerta, un encadenado de puertos por la Vall d’Albaida o una escapada al mar por la Valldigna.
          </p>
          <p>
            A ese privilegio geográfico se suma el clima (más de 300 días de sol al año), una red de carreteras secundarias tranquilas y una cultura local que lleva décadas acogiendo pelotones: no eres un extraño, eres un visitante bienvenido.
          </p>
        </div>

        <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-white/5 border border-white/10 rounded-xl p-4">
            <div class="text-emerald-400 text-xs font-semibold uppercase tracking-wider">Norte</div>
            <div class="mt-1 text-white font-bold">La Ribera y costa</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4">
            <div class="text-emerald-400 text-xs font-semibold uppercase tracking-wider">Sur</div>
            <div class="mt-1 text-white font-bold">Vall d’Albaida</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4">
            <div class="text-emerald-400 text-xs font-semibold uppercase tracking-wider">Este</div>
            <div class="mt-1 text-white font-bold">Mondúver y mar</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4">
            <div class="text-emerald-400 text-xs font-semibold uppercase tracking-wider">Oeste</div>
            <div class="mt-1 text-white font-bold">Canal de Navarrés</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contacto -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="bg-gradient-to-br from-emerald-50 via-white to-sky-50 rounded-3xl border border-emerald-100 p-8 md:p-12 text-center">
        <div class="text-5xl mb-4">✉️</div>
        <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">
          ¿Me ayudas a mejorar?
        </h2>
        <p class="mt-4 text-slate-600 text-lg max-w-2xl mx-auto">
          ¿Conoces una ruta que no está aquí? ¿Un bar ciclista imprescindible? ¿Has detectado un error? ¿Quieres colaborar con contenido propio? Escríbeme: esta web se hace mejor con la comunidad ciclista local.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="mailto:info@paraisociclista.com"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-semibold shadow-lg shadow-emerald-500/30 hover:shadow-xl hover:shadow-emerald-500/40 transition-all"
          >
            info@paraisociclista.com
          </a>
          <a
            href="/rutas"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white border border-slate-200 text-slate-700 font-semibold hover:bg-slate-50 transition-colors"
          >
            Ver rutas →
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
