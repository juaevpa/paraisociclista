---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

const stats = [
  { value: '300+', label: 'Días de sol al año' },
  { value: '6', label: 'Rutas verificadas' },
  { value: '4', label: 'Comarcas al alcance' },
  { value: '775', label: 'Años de la Fira d’Agost' },
];

const values = [
  {
    num: '01',
    title: 'Rutas probadas, no copiadas',
    text: 'Cada itinerario que publico lo he rodado metro a metro. Sé dónde hay una fuente operativa, qué bar abre el domingo por la mañana y qué puerto conviene afrontar a primera hora.',
  },
  {
    num: '02',
    title: 'Cicloturismo con potencial',
    text: 'Xàtiva tiene todo lo que un destino cicloturista puede ofrecer: clima, orografía, patrimonio, gastronomía y carreteras tranquilas. Falta ordenarlo y contarlo bien. Esa es la misión.',
  },
  {
    num: '03',
    title: 'Conocimiento local',
    text: 'No hablo de oídas. Vivo aquí, como arròs al forn habitualmente, subo al castillo al amanecer y sé por qué el retrato de Felipe V sigue cabeza abajo en el Almodí.',
  },
  {
    num: '04',
    title: 'Proyecto abierto',
    text: 'Esta web crece con quien la usa. Si echas en falta una ruta, un taller o un bar bike-friendly, escríbeme y lo incorporo. La comunidad ciclista local está invitada a colaborar.',
  },
];

const offerings = [
  { title: 'Rutas con GPX', text: 'Mapas, desnivel, duración, dificultad y tracks descargables compatibles con Wikiloc, Komoot y Strava.' },
  { title: 'Guía gastronómica', text: 'Restaurantes, bares de pueblo y obradores históricos donde comer de verdad: arròs al forn, arnadí, moixavena.' },
  { title: 'Alojamiento', text: 'Selección de hoteles, casas rurales y apartamentos adaptados a ciclistas en Xàtiva y comarca.' },
  { title: 'Cultura y patrimonio', text: 'El castillo, la Seu, el Museu de l’Almodí, los Borgia: lo que hay que parar a ver entre pedalada y pedalada.' },
  { title: 'Consejos prácticos', text: 'Mejores épocas, mecánica básica, talleres de bici en Xàtiva, puntos de agua, seguridad vial y preparación.' },
  { title: 'Eventos y pruebas', text: 'Volta a la Comunitat Valenciana, concentraciones invernales, grupetas locales y marchas populares.' },
];
---

<Layout title="Sobre Paraíso Ciclista" description="Paraíso Ciclista: la guía independiente para descubrir Xàtiva en bicicleta, hecha por ciclistas locales que conocen cada carretera, fuente y bar del camino.">
  <Header />

  <main class="flex-1 bg-white">
    <!-- HERO editorial con foto panorámica -->
    <section class="relative overflow-hidden bg-stone-900">
      <img
        src="/images/blog/xativa-panoramic.jpg"
        alt="Vista panorámica de Xàtiva"
        class="absolute inset-0 w-full h-full object-cover opacity-50"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-stone-900/50 via-stone-900/30 to-stone-900/70"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
        <div class="max-w-3xl">
          <p class="text-[11px] uppercase tracking-[0.35em] font-semibold text-white/80 mb-6">
            El proyecto · Paraíso Ciclista
          </p>
          <h1 class="font-serif text-white font-light leading-[0.98] tracking-tight text-5xl md:text-6xl lg:text-7xl">
            La guía <em class="italic font-normal">honesta</em><br />
            de Xàtiva para<br />
            quien rueda
          </h1>
          <p class="mt-8 text-lg md:text-xl text-white/85 max-w-xl leading-relaxed">
            Un proyecto personal e independiente para poner en valor el enorme potencial cicloturista de Xàtiva y su comarca. Rutas probadas, consejos reales y una mirada auténtica sobre una tierra con una tradición ciclista profunda.
          </p>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="relative border-t border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
            {stats.map((s) => (
              <div class="py-5 md:py-6 px-2 md:px-6">
                <div class="font-serif text-2xl md:text-3xl font-light text-white">{s.value}</div>
                <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-white/70">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- POR QUÉ EXISTE -->
    <section class="border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
          <div class="lg:col-span-5">
            <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
              Capítulo · 01
            </p>
            <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-[1.05] tracking-tight">
              ¿Por qué<br />
              <em class="italic font-normal">existe</em> esta web?
            </h2>
          </div>
          <div class="lg:col-span-7 space-y-5 text-stone-700 text-lg leading-relaxed">
            <p>
              Paraíso Ciclista es un proyecto <strong class="text-stone-900">personal</strong>. Detrás no hay una empresa ni un colectivo: hay una persona, aficionada al ciclismo, que vive en Xàtiva y tiene una convicción clara: <strong class="text-stone-900">esta comarca tiene un potencial cicloturista enorme y aún por poner en valor</strong>.
            </p>
            <p>
              Xàtiva no necesita inventarse como destino ciclista; ya lo es desde hace generaciones. Los clubes locales llevan décadas formando ciclistas, los sábados por la mañana los puertos de la Vall d’Albaida y del Canal de Navarrés se llenan de grupetas, y en los bares de los pueblos los maillots y los cafés conviven con una naturalidad que solo da la costumbre. Aquí se pedalea mucho y bien; solo faltaba contarlo.
            </p>
            <p>
              Pero cuando buscaba información online para planificar rutas, recomendar la zona a amigos de fuera o explicar por qué merece la pena venir, solo encontraba guías copiadas unas de otras, datos desactualizados, rutas que nadie había pedaleado y recomendaciones gastronómicas genéricas. Xàtiva merece una guía mejor.
            </p>
            <p>
              Esta es mi aportación: una guía honesta, rodada, verificada y con memoria local. Sin patrocinios de marcas, ayuntamientos ni hoteles. Si recomiendo un restaurante es porque he comido allí; si publico una ruta es porque la he rodado.
            </p>
            <p>
              El objetivo a medio plazo es sencillo pero ambicioso: que quien busque "cicloturismo en la Comunitat Valenciana" encuentre Xàtiva entre las primeras respuestas, con razones sobradas para venir.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CÓMO TRABAJO -->
    <section class="border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="mb-14">
          <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
            Capítulo · 02
          </p>
          <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-[1.05] tracking-tight max-w-3xl">
            Cuatro principios<br />
            <em class="italic font-normal">que orientan</em> esta guía
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-t border-stone-200">
          {values.map((v, i) => (
            <div class={`p-8 md:p-10 border-b border-stone-200 ${i % 2 === 0 ? 'md:border-r' : ''}`}>
              <div class="flex items-start gap-6">
                <span class="font-serif text-2xl md:text-3xl font-light text-stone-300 leading-none shrink-0">
                  {v.num}
                </span>
                <div>
                  <h3 class="text-xl md:text-2xl font-bold text-stone-900 leading-tight mb-3">
                    {v.title}
                  </h3>
                  <p class="text-stone-600 leading-relaxed">{v.text}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TRADICIÓN CICLISTA -->
    <section class="border-b border-stone-200 bg-stone-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
          <div class="lg:col-span-5">
            <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
              Capítulo · 03
            </p>
            <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-[1.05] tracking-tight">
              Xàtiva es,<br />
              históricamente,<br />
              <em class="italic font-normal">tierra de ciclistas</em>
            </h2>
            <p class="mt-6 text-lg text-stone-600 leading-relaxed max-w-md">
              Aquí el ciclismo no es una moda: es costumbre. Décadas de clubes locales, aficionados que suben al castillo en bici antes del desayuno y pelotones de fin de semana que dominan las carreteras de la comarca.
            </p>
          </div>

          <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-stone-200">
            <div class="p-6 md:p-7 border-b md:border-b-0 md:border-r border-stone-200 bg-white">
              <div class="font-serif text-4xl font-light text-stone-900 leading-none">Clubes</div>
              <div class="mt-4 text-[11px] uppercase tracking-[0.2em] font-semibold text-stone-500">Cantera activa</div>
              <p class="mt-3 text-sm text-stone-600 leading-relaxed">
                Xàtiva, Canals, Genovés, Ontinyent mantienen clubes con décadas de historia y escuelas formativas.
              </p>
            </div>
            <div class="p-6 md:p-7 border-b md:border-b-0 md:border-r border-stone-200 bg-white">
              <div class="font-serif text-4xl font-light text-stone-900 leading-none">Volta</div>
              <div class="mt-4 text-[11px] uppercase tracking-[0.2em] font-semibold text-stone-500">Comunitat Valenciana</div>
              <p class="mt-3 text-sm text-stone-600 leading-relaxed">
                La Volta CV pasa regularmente por estas carreteras: tramos probados al máximo nivel profesional cada febrero.
              </p>
            </div>
            <div class="p-6 md:p-7 bg-white">
              <div class="font-serif text-4xl font-light text-stone-900 leading-none">Grupetas</div>
              <div class="mt-4 text-[11px] uppercase tracking-[0.2em] font-semibold text-stone-500">Ciclismo popular</div>
              <p class="mt-3 text-sm text-stone-600 leading-relaxed">
                Cada sábado y domingo salen decenas de grupetas por la Costera, la Vall d’Albaida y el Canal de Navarrés.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- QUÉ VAS A ENCONTRAR -->
    <section class="border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="mb-14">
          <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
            Capítulo · 04
          </p>
          <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-[1.05] tracking-tight max-w-3xl">
            Qué vas a <em class="italic font-normal">encontrar</em>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0 border-t border-l border-stone-200">
          {offerings.map((o, i) => (
            <div class="p-8 md:p-10 border-r border-b border-stone-200 relative">
              <span class="font-serif text-2xl font-light text-stone-300 absolute top-6 right-6">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="text-lg md:text-xl font-bold text-stone-900 mb-3 pr-10">{o.title}</h3>
              <p class="text-sm text-stone-600 leading-relaxed">{o.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACTO -->
    <section>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="max-w-3xl">
          <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-stone-500 mb-4">
            Colabora · Contacto
          </p>
          <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-[1.05] tracking-tight">
            ¿Me ayudas<br />
            a <em class="italic font-normal">mejorar</em>?
          </h2>
          <p class="mt-6 text-lg md:text-xl text-stone-600 leading-relaxed max-w-2xl">
            ¿Conoces una ruta que no está aquí? ¿Un bar ciclista imprescindible? ¿Has detectado un error? ¿Quieres colaborar con contenido propio? Escríbeme: esta web se hace mejor con la comunidad ciclista local.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a
              href="mailto:info@paraisociclista.com"
              class="inline-flex items-center gap-3 px-6 py-3.5 bg-stone-900 text-white font-semibold text-sm uppercase tracking-wider hover:bg-stone-800 transition-colors"
            >
              info@paraisociclista.com
              <span aria-hidden="true">→</span>
            </a>
            <a
              href="/rutas"
              class="inline-flex items-center gap-3 px-6 py-3.5 text-stone-900 font-semibold text-sm uppercase tracking-wider border border-stone-300 hover:bg-stone-100 transition-colors"
            >
              Ver rutas
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
