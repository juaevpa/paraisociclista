---
import { urlFor } from '@/lib/sanity';

interface Props {
  route: any;
  index?: number;
}

const { route, index } = Astro.props;

const colorAccent: Record<string, string> = {
  green: 'text-emerald-700',
  yellow: 'text-amber-700',
  orange: 'text-orange-700',
  red: 'text-red-700',
};

const colorDot: Record<string, string> = {
  green: 'bg-emerald-500',
  yellow: 'bg-amber-500',
  orange: 'bg-orange-500',
  red: 'bg-red-500',
};

const diff = route.difficulty && typeof route.difficulty === 'object' ? {
  label: route.difficulty.title || 'Ruta',
  accent: colorAccent[route.difficulty.color] || 'text-slate-700',
  dot: colorDot[route.difficulty.color] || 'bg-slate-400',
} : null;

const routeType = route.routeType && typeof route.routeType === 'object' ? route.routeType.title : null;
const indexLabel = typeof index === 'number' ? String(index + 1).padStart(2, '0') : null;
const href = `/rutas/${route.slug.current}`;
---

<article class="group relative h-full">
  <a
    href={href}
    class="flex flex-col h-full bg-stone-50 hover:bg-white border border-stone-200 hover:border-stone-900 transition-all duration-300 overflow-hidden"
  >
    {route.mainImage && (
      <div class="relative aspect-[5/3] overflow-hidden bg-stone-100">
        <img
          src={urlFor(route.mainImage).width(800).height(480).url()}
          alt={route.title}
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
          loading="lazy"
        />
      </div>
    )}

    <div class="flex flex-col flex-1 p-6 md:p-7">
      <!-- Top row: index + featured -->
      <div class="flex items-start justify-between mb-5">
        {indexLabel && (
          <span class="font-serif text-3xl md:text-4xl font-light text-stone-300 leading-none tracking-tight">
            {indexLabel}
          </span>
        )}
        {route.featured && (
          <span class="text-[10px] uppercase tracking-[0.2em] font-semibold text-amber-700 bg-amber-50 px-2 py-1 border border-amber-200">
            Destacada
          </span>
        )}
      </div>

      <!-- Title -->
      <h3 class="text-xl md:text-2xl font-black text-stone-900 leading-[1.15] tracking-tight mb-2">
        {route.title}
      </h3>

      {route.excerpt && (
        <p class="text-sm text-stone-600 leading-relaxed mb-5 line-clamp-2">
          {route.excerpt}
        </p>
      )}

      <!-- Spacer -->
      <div class="flex-1"></div>

      <!-- Stats row -->
      {(route.distance || route.elevation || route.duration) && (
        <div class="grid grid-cols-3 gap-3 mt-6 pt-5 border-t border-stone-200">
          {route.distance !== undefined && (
            <div>
              <div class="font-serif text-2xl md:text-[28px] font-semibold text-stone-900 leading-none">
                {route.distance}
                <span class="text-sm font-sans font-medium text-stone-500 ml-0.5">km</span>
              </div>
              <div class="mt-1 text-[10px] uppercase tracking-[0.15em] text-stone-500">Distancia</div>
            </div>
          )}
          {route.elevation && (
            <div>
              <div class="font-serif text-2xl md:text-[28px] font-semibold text-stone-900 leading-none">
                {route.elevation >= 1000 ? `${(route.elevation / 1000).toFixed(1)}k` : route.elevation}
                <span class="text-sm font-sans font-medium text-stone-500 ml-0.5">m</span>
              </div>
              <div class="mt-1 text-[10px] uppercase tracking-[0.15em] text-stone-500">Desnivel</div>
            </div>
          )}
          {route.duration && (
            <div>
              <div class="font-serif text-2xl md:text-[28px] font-semibold text-stone-900 leading-none">
                {route.duration.split(':')[0]}
                <span class="text-sm font-sans font-medium text-stone-500 ml-0.5">h</span>
              </div>
              <div class="mt-1 text-[10px] uppercase tracking-[0.15em] text-stone-500">Duración</div>
            </div>
          )}
        </div>
      )}

      <!-- Footer row: type/difficulty + arrow -->
      <div class="flex items-center justify-between mt-5 pt-4 border-t border-stone-200">
        <div class="flex items-center gap-3 text-[11px] uppercase tracking-[0.2em] font-semibold">
          {routeType && <span class="text-stone-600">{routeType}</span>}
          {routeType && diff && <span class="text-stone-300">·</span>}
          {diff && (
            <span class={`inline-flex items-center gap-1.5 ${diff.accent}`}>
              <span class={`w-1.5 h-1.5 rounded-full ${diff.dot}`}></span>
              {diff.label}
            </span>
          )}
        </div>
        <span class="text-stone-900 group-hover:translate-x-1 transition-transform duration-300" aria-hidden="true">
          →
        </span>
      </div>
    </div>
  </a>
</article>
