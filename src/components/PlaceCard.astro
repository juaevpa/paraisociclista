---
import { urlFor } from '@/lib/sanity';

interface Props {
  place: {
    _id: string;
    title: string;
    slug: { current: string };
    mainImage?: any;
    rating?: number;
  };
  type: 'restaurant' | 'hotel';
}

const { place, type } = Astro.props;

const baseUrl = type === 'restaurant' ? '/restaurantes' : '/alojamiento';
const label = type === 'restaurant' ? 'Restaurante' : 'Alojamiento';
---

<a href={`${baseUrl}/${place.slug.current}`} class="group flex flex-col">
  <div class="relative aspect-square overflow-hidden bg-stone-100 mb-3">
    {place.mainImage ? (
      <img
        src={urlFor(place.mainImage).width(500).height(500).url()}
        alt={place.title}
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 bg-stone-200 flex items-center justify-center">
        <span class="font-serif text-3xl font-light text-stone-400">
          {place.title.charAt(0)}
        </span>
      </div>
    )}
    {place.rating && (
      <div class="absolute top-2 right-2 px-2 py-0.5 bg-white/90 backdrop-blur text-[10px] uppercase tracking-wider font-semibold text-stone-900">
        {place.rating.toFixed(1)}
      </div>
    )}
  </div>

  <p class="text-[10px] uppercase tracking-[0.2em] font-semibold text-stone-500 mb-1">
    {label}
  </p>
  <h3 class="text-sm font-semibold text-stone-900 leading-snug group-hover:text-stone-600 transition-colors line-clamp-2">
    {place.title}
  </h3>
</a>
