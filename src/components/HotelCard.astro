---
import { urlFor } from '@/lib/sanity';

interface Props {
  hotel: {
    _id: string;
    title: string;
    slug: { current: string };
    mainImage?: any;
    rating?: number;
    priceLevel?: number;
    address?: string;
  };
}

const { hotel } = Astro.props;
---

<article class="group bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl transition-all duration-300">
  <a href={`/alojamiento/${hotel.slug.current}`} class="block aspect-video overflow-hidden bg-slate-100">
    {hotel.mainImage ? (
      <img 
        src={urlFor(hotel.mainImage).width(600).height(338).url()} 
        alt={hotel.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-blue-100 to-indigo-100 flex items-center justify-center">
        <span class="text-4xl">🏨</span>
      </div>
    )}
  </a>
  
  <div class="p-5">
    <a href={`/alojamiento/${hotel.slug.current}`}>
      <h3 class="text-lg font-semibold text-slate-900 group-hover:text-primary-600 transition-colors line-clamp-2">
        {hotel.title}
      </h3>
    </a>
    
    <div class="flex items-center justify-between mt-3">
      {hotel.rating && (
        <div class="flex items-center gap-1">
          <span class="text-amber-400">★</span>
          <span class="text-sm font-medium text-slate-700">{hotel.rating}</span>
        </div>
      )}
      
      {hotel.priceLevel && (
        <span class="text-sm text-slate-500">
          {'€'.repeat(hotel.priceLevel)}
        </span>
      )}
    </div>
    
    {hotel.address && (
      <p class="mt-2 text-sm text-slate-500 line-clamp-1">📍 {hotel.address}</p>
    )}
  </div>
</article>
