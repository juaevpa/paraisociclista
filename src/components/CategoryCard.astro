---
import { getCategoryImageFor } from '@/lib/placeImages';

interface Props {
  category: {
    _id: string;
    title: string;
    slug: { current: string };
    description?: string;
    image?: any;
  };
}

const { category } = Astro.props;
const imgUrl = getCategoryImageFor(category);
const href = `/explorar/${category.slug.current}`;
---

<a href={href} class="group relative block overflow-hidden bg-stone-100 aspect-[4/5]">
  {imgUrl ? (
    <>
      <img
        src={imgUrl}
        alt={category.title}
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-stone-900/80 via-stone-900/20 to-transparent"></div>
    </>
  ) : (
    <div class="absolute inset-0 bg-stone-200"></div>
  )}

  <div class="absolute inset-0 flex flex-col justify-end p-5 md:p-6">
    <p class="text-[10px] uppercase tracking-[0.3em] font-semibold text-white/80 mb-2">
      Explorar
    </p>
    <h3 class="font-serif text-white font-light text-2xl md:text-3xl leading-[1.05] tracking-tight">
      {category.title}
    </h3>
    {category.description && (
      <p class="mt-2 text-sm text-white/85 leading-relaxed line-clamp-2">
        {category.description}
      </p>
    )}
    <div class="mt-3 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] font-semibold text-white group-hover:gap-3 transition-all">
      Ver <span aria-hidden="true">→</span>
    </div>
  </div>
</a>
