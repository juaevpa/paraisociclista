---
import Logo from './Logo.astro';

const quickLinks = [
  { href: '/rutas', label: 'Rutas' },
  { href: '/explorar', label: 'Explorar' },
  { href: '/restaurantes', label: 'Restaurantes' },
  { href: '/alojamiento', label: 'Alojamiento' },
  { href: '/blog', label: 'Diario' },
  { href: '/sobre-nosotros', label: 'Sobre nosotros' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-950 text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <!-- Logo + descripción -->
      <div class="md:col-span-5">
        <Logo theme="dark" />
        <p class="mt-6 text-stone-400 text-base leading-relaxed max-w-md">
          Una guía independiente para descubrir Xàtiva y su comarca sobre dos ruedas. Rutas probadas, consejos reales y memoria local.
        </p>
      </div>

      <!-- Navegación -->
      <div class="md:col-span-4">
        <p class="text-[10px] uppercase tracking-[0.25em] font-semibold text-stone-500 mb-5">
          Navegar
        </p>
        <ul class="grid grid-cols-2 gap-y-3 gap-x-6">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-stone-300 hover:text-white transition-colors text-sm inline-flex items-center gap-2 group"
              >
                <span class="group-hover:translate-x-0.5 transition-transform">{link.label}</span>
                <span class="text-stone-600 group-hover:text-white transition-colors" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div class="md:col-span-3">
        <p class="text-[10px] uppercase tracking-[0.25em] font-semibold text-stone-500 mb-5">
          Contacto
        </p>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="mailto:info@paraisociclista.com" class="text-stone-300 hover:text-white transition-colors">
              info@paraisociclista.com
            </a>
          </li>
          <li class="text-stone-400">Xàtiva, València</li>
          <li class="text-stone-400">Comunitat Valenciana</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-6 border-t border-stone-800 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-xs text-stone-500">
      <p>© {currentYear} Paraíso Ciclista · Proyecto personal e independiente</p>
      <p class="uppercase tracking-[0.2em] font-semibold text-stone-600">
        Hecho en Xàtiva
      </p>
    </div>
  </div>
</footer>
