---
const quickLinks = [
  { href: '/rutas', label: 'Rutas' },
  { href: '/explorar', label: 'Explorar Xàtiva' },
  { href: '/blog', label: 'Blog' },
  { href: '/sobre-nosotros', label: 'Sobre nosotros' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Logo y descripción -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-sky-500 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 256 256">
              <path d="M164.38,181.1a52,52,0,1,1-72.76,0l13.21-30.06A44,44,0,1,0,128,88a44.05,44.05,0,0,0-43.17,35.44L61.57,182.26a4,4,0,0,1-7.14,0L31.17,123.44a44,44,0,1,0,0,52.12l13.21,30.06a52,52,0,1,1,72.76,0l-13.21-30.06a44,44,0,1,0,0-52.12l13.21,30.06a52,52,0,0,1,47.24-41.5l13.21-30.06a52,52,0,1,1,0-52.12Z"/>
            </svg>
          </div>
          <span class="text-xl font-bold">Paraíso Ciclista</span>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed">
          Descubre las mejores rutas ciclistas en Xàtiva y sus alrededores. 
          Explora la historia, gastronomía y naturaleza de nuestra región.
        </p>
      </div>
      
      <!-- Enlaces rápidos -->
      <div>
        <h3 class="font-semibold text-lg mb-4">Enlaces rápidos</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="text-slate-400 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Contacto -->
      <div>
        <h3 class="font-semibold text-lg mb-4">Contacto</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-400 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@paraisociclista.com" class="hover:text-white transition-colors">
              info@paraisociclista.com
            </a>
          </li>
          <li class="flex items-center gap-3 text-slate-400 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Xàtiva, Valencia, España</span>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-slate-800">
      <p class="text-slate-500 text-sm text-center">
        © {currentYear} Paraíso Ciclista. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
